{
  "name": "ischeduler",
  "version": "0.1.7",
  "description": "Recurring event scheduler UI components for React + Ant Design",
  "license": "MIT",
  "repository": "https://github.com/ischeduler/ischeduler",
  "author": "Vladimir Tkach",
  "keywords": [
    "react",
    "antd",
    "scheduler",
    "recurring events",
    "calendar",
    "date picker"
  ],
  "type": "module",
  "main": "storybook-static/iScheduler.cjs.js",
  "module": "storybook-static/iScheduler.es.js",
  "types": "storybook-static/index.d.ts",
  "files": [
    "storybook-static"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,less}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.3.3",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/react": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "antd": "^6.3.3",
    "dayjs": "^1.11.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.0",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "storybook": "^10.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
