{
  "name": "@teamco/ischeduler-storybook",
  "version": "2.0.17",
  "private": true,
  "description": "Unified Storybook for all iScheduler adapters",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.cjs -i src/styles/shadcn-input.css -o src/styles/shadcn-compiled.css --minify",
    "storybook": "npm run build:css && storybook dev -p 6006",
    "build-storybook": "npm run build:css && storybook build -o dist/storybook"
  },
  "dependencies": {
    "@teamco/ischeduler-antd": "*",
    "@teamco/ischeduler-core": "*",
    "@teamco/ischeduler-mui": "*",
    "@teamco/ischeduler-shadcn": "*"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.0",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/global": "^5.0.0",
    "@storybook/react-vite": "^10.3.5",
    "antd": "^6.3.3",
    "autoprefixer": "^10.4.27",
    "dayjs": "^1.11.20",
    "eslint-plugin-storybook": "10.3.5",
    "less": "^4.6.4",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^8.0.0"
  }
}
