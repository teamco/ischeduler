{
  "name": "@teamco/ischeduler-antd",
  "version": "2.0.11",
  "description": "iScheduler UI components for React + Ant Design",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamco/ischeduler.git"
  },
  "author": "Vladimir Tkach",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "antd",
    "ant-design",
    "scheduler",
    "recurring events",
    "calendar"
  ],
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,less}\""
  },
  "peerDependencies": {
    "@ant-design/icons": "^6.1.0",
    "@teamco/ischeduler-core": "*",
    "antd": "^6.3.5",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.1",
    "@teamco/ischeduler-core": "*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "antd": "^6.3.5",
    "dayjs": "^1.11.20",
    "jsdom": "^29.0.0",
    "less": "^4.6.4",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^1.0.5",
    "vitest": "^4.1.2"
  }
}
