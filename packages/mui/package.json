{
  "name": "@teamco/ischeduler-mui",
  "version": "2.4.5",
  "description": "iScheduler UI components for React + MUI (Material UI)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamco/ischeduler.git"
  },
  "author": "Vladimir Tkach",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "mui",
    "material-ui",
    "scheduler",
    "recurring events"
  ],
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/x-date-pickers": "^9.7.0",
    "@teamco/ischeduler-core": "*",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@teamco/ischeduler-core": "*",
    "dayjs": "^1.11.21",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  }
}
