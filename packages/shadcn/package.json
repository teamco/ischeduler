{
  "name": "@teamco/ischeduler-shadcn",
  "version": "2.6.0",
  "description": "iScheduler UI components for React + shadcn/ui (Radix UI + Tailwind)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamco/ischeduler.git"
  },
  "author": "Vladimir Tkach",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "shadcn",
    "radix-ui",
    "tailwind",
    "scheduler",
    "recurring events"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit && vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "@radix-ui/react-accordion": "^1",
    "@radix-ui/react-checkbox": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-label": "^2",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-radio-group": "^1",
    "@radix-ui/react-select": "^2",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-tabs": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@teamco/ischeduler-core": "*",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@teamco/ischeduler-core": "*",
    "dayjs": "^1.11.21",
    "jsdom": "^29.1.1",
    "tw-animate-css": "^1",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.9"
  }
}
