{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@teamco/ischeduler-core": ["packages/core/src/index.ts"],
      "@teamco/ischeduler-antd": ["packages/antd/src/index.ts"],
      "@teamco/ischeduler-mui": ["packages/mui/src/index.ts"],
      "@teamco/ischeduler-shadcn": ["packages/shadcn/src/index.ts"]
    }
  },
  "include": ["src/**/*", "__tests__/**/*"],
  "exclude": ["node_modules", "dist"]
}
